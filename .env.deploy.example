# 本番デプロイ用の環境変数テンプレート。
# このファイルを .env.deploy にコピーして値を埋め、Gitにはコミットしないこと。
# 使い方: docker compose --env-file .env.deploy up -d --build

# 公開ドメイン（Caddyが自動でHTTPS証明書を取得する宛先）
DOMAIN=salespro.example.com
# アプリが生成するリンク(メール確認URL等)に使う。https:// 付き・末尾スラッシュなし
SITE_URL=https://salespro.example.com

# 最初に管理者になるメールアドレス（このメールで登録したユーザーが自動で管理者・確認済みになる）
ADMIN_EMAIL=admin@example.com

# 声クローン機能。実音声で品質確認できるまでは false 推奨
FEATURE_VOICE_CLONE=false

# メール確認用SMTP（任意・未設定なら確認リンクはサーバーログに出力）
# 例: SendGrid / Gmailアプリパスワード / SES など
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ※ AIのAPIキー(Anthropic/OpenAI/Fish)はここに書かない。全て利用者のBYOK。
